# ============================================================
# Storage & path configuration
# Copy this file to .env and adjust values as needed.
# All variables are optional; defaults are shown below.
# ============================================================

# Full path to the SQLite database file used to persist job metadata.
# Default: ~/video_data/video_jobs.db
# VIDEO_JOBS_DB=/data/video_jobs.db

# Directory where processed video output files are written.
# Default: ~/video_data/video_outputs
# VIDEO_OUTPUT_DIR=/data/video_outputs

# Seconds an undownloaded job is kept before it is considered abandoned
# and automatically purged. Set higher on slow networks.
# Default: 3600  (1 hour)
# VIDEO_JOB_TTL=3600

# Maximum total bytes allowed across all output files before the oldest
# completed jobs are evicted. Set to 0 to disable the disk cap.
# Default: 2147483648  (2 GiB)
# VIDEO_JOB_MAX_BYTES=2147483648

# Number of frames to skip between processed frames during face-swap.
# Higher values are faster but lower quality. 1 means every frame.
# Default: 2
# VIDEO_FRAME_SKIP=2
